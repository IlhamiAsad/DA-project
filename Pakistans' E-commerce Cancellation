# Customer Segmentation (High value, High Risk, Reguler)
def segment_customer(row):
    if row['completion_rate'] >= 0.8 and row['net_revenue'] > customer_behavior['net_revenue'].median():
        return 'High Value'
    elif row['completion_rate'] < 0.5:
        return 'High Risk'
    else:
        return 'Regular'

customer_behavior['segment'] = customer_behavior.apply(segment_customer, axis=1)
customer_behavior.head()


# Visualization for Segmentation
