##### Elbow Method

# get the inertia
cluster_model.inertia_

# create empty list to store the inertia value for each K later
inertia_values = []
K_range = range(2, 15)

for K in K_range:
    # create the model
    cluster_model = KMeans(n_clusters=K, random_state=42, n_init='auto')
    # Train them using "df_minmax" data (our final data scaled by min max scaler)
    cluster_model.fit(df_minmax)
    # get the intertia value and put it our empty list "inertia_values"
    inertia_values.append(cluster_model.inertia_)

# print output
print(inertia_values)

# define canvas
plt.figure(figsize=(13,4))

# plot the lineplot using matplotib
# x-axis -> K_range, y-axis -> intertia
# "b*-" in the third parameter to do styling (b: blue, *: star mark each point, -: connect by line)
plt.plot(K_range, inertia_values, 'b*-')
plt.xlabel('Number of Clusters (K)')
plt.ylabel('Inertia')
plt.title('Elbow Method')


