### Identify Business Oppotunities

segment_summary = rfm_final.groupby(['segment', 'Actionable']).agg(
    count_of_customers=('id', 'count'),
    mean_monetary=('monetary', 'mean')
).reset_index()

print("Customer Segment Summary (Segment, Actionable, Count, Mean Monetary):")
